{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "market-signal-ai-bot",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-02",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "ENVIRONMENT": "production",
    "PUBLIC_APP_NAME": "Market Signal AI",
    "DEFAULT_LOCALE": "en",
    "DEFAULT_COUNTRY": "US"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "market-signal-ai-bot-db",
      "database_id": "ebc41219-4276-4068-adb4-1a78d0f0192f",
      "migrations_dir": "migrations"
    }
  ]
}
